# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments and are ignored.

# ---- Server ----
PORT=10000
NODE_ENV=development

# ---- Admin ----
# If you don't set this, a random key is generated at startup and printed
# to the console (it changes every restart). Set a real value before you
# deploy anywhere other than your own machine.
FIXIT_API_KEY=12345

# ---- Email / OTP provider (SMTP) ----
# Without this, OTP codes only print to the server console (and, outside
# production, are also returned in the API response for local testing).
# Works with Gmail (use an App Password), Outlook, Zoho, SendGrid SMTP relay,
# or any provider that supports implicit TLS (usually port 465).
SMTP_HOST=SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=episkeviservices200@Gmail.com
SMTP_PASS=cpql aser xdwr pjws
SMTP_FROM=episkeviservices200@Gmail.com
SMTP_FROM_NAME=Episkevi


