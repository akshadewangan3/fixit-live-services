# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments and are ignored.

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Admin ----
# If you don't set this, a random key is generated at startup and printed
# to the console (it changes every restart). Set a real value before you
# deploy anywhere other than your own machine.
FIXIT_API_KEY=

# ---- SMS / OTP provider (set ONE of these two options) ----
# Without either, OTP codes only print to the server console (and, outside
# production, are also returned in the API response for local testing).

# Option A: MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=


# ---- Payments ----
FIXIT_UPI_ID=test@razorpay
FIXIT_MERCHANT_NAME=FixIt
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
